---
import FadeIn from "~/components/atoms/FadeIn.astro";
---

<section class="bg-indigo-600">
  <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6 sm:py-28 lg:px-8">
    <FadeIn>
      <h2
        class="font-display text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl lg:text-5xl"
      >
        Email, meet privacy.
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-lg text-pretty text-indigo-100">
        Start your free 30-day trial. No credit card, no catch, just a quieter
        inbox.
      </p>
      <div class="mt-8 flex justify-center">
        <a
          href="https://app.shroud.email/users/register"
          class="inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 font-medium text-indigo-700 shadow-sm transition-colors hover:bg-indigo-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-indigo-600"
        >
          Start your free trial
        </a>
      </div>
    </FadeIn>
  </div>
</section>
