---
import FadeIn from "~/components/atoms/FadeIn.astro";

const features = [
  {
    name: "Unlimited aliases",
    description:
      "Make a fresh alias every time a website asks for your email. No arbitrary limits, ever.",
    icon: "M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75",
  },
  {
    name: "Stop spammers cold",
    description:
      "Block a spammy sender at will, or give a noisy alias a holiday by switching it off entirely.",
    icon: "M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636",
  },
  {
    name: "Block trackers",
    description:
      "Senders don't get to know if or when you read their mail. Shroud.email strips tracking pixels so your privacy stays intact.",
    icon: "M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88",
  },
  {
    name: "Reply from your aliases",
    description:
      "Aliases aren't just for receiving. Send outgoing mail too, without ever revealing your real address.",
    icon: "M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3",
  },
  {
    name: "Fully open-source",
    description:
      "Every part of Shroud.email is open source, licensed under the AGPL v3. Read it, run it, trust it.",
    icon: "M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5",
  },
  {
    name: "Privacy that's light on the planet",
    description:
      "Shroud.email runs on 100% renewable energy, hosted in the EU.",
    icon: "m20.893 13.393-1.135-1.135a2.252 2.252 0 0 1-.421-.585l-1.08-2.16a.414.414 0 0 0-.663-.107.827.827 0 0 1-.812.21l-1.273-.363a.89.89 0 0 0-.738 1.595l.587.39c.59.395.674 1.23.172 1.732l-.2.2c-.212.212-.33.498-.33.796v.41c0 .409-.11.809-.32 1.158l-1.315 2.191a2.11 2.11 0 0 1-1.81 1.025 1.055 1.055 0 0 1-1.055-1.055v-1.172c0-.92-.56-1.747-1.414-2.089l-.655-.261a2.25 2.25 0 0 1-1.383-2.46l.007-.042a2.25 2.25 0 0 1 .29-.787l.09-.15a2.25 2.25 0 0 1 2.37-1.048l1.178.236a1.125 1.125 0 0 0 1.302-.795l.208-.73a1.125 1.125 0 0 0-.578-1.315l-.665-.332-.091.091a2.25 2.25 0 0 1-1.591.659h-.18c-.249 0-.487.1-.662.274a.931.931 0 0 1-1.458-1.137l1.411-2.353a2.25 2.25 0 0 0 .286-.76m11.928 9.869A9 9 0 0 0 8.965 3.525m11.928 9.868A9 9 0 1 1 8.965 3.525",
  },
];
---

<section class="bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
    <FadeIn>
      <div class="max-w-2xl">
        <h2
          class="font-display text-3xl font-semibold tracking-tight text-balance text-slate-900 sm:text-4xl lg:text-5xl"
        >
          What Shroud.email can do
        </h2>
        <p class="mt-4 max-w-prose text-lg text-slate-600">
          Take back control of your inbox, with no limits and no asterisks.
        </p>
      </div>
    </FadeIn>

    <FadeIn>
      <div
        class="mt-12 grid grid-cols-1 gap-px overflow-hidden rounded-2xl bg-slate-200 ring-1 ring-slate-200 sm:mt-16 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          features.map((feature) => (
            <div class="bg-slate-50 p-6 transition-colors hover:bg-white lg:p-8">
              <div class="flex items-center gap-3">
                <svg
                  class="size-5 flex-none text-indigo-500"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={feature.icon} />
                </svg>
                <h3 class="font-display text-lg font-semibold text-slate-900">
                  {feature.name}
                </h3>
              </div>
              <p class="mt-3 leading-relaxed text-slate-600">
                {feature.description}
              </p>
            </div>
          ))
        }
      </div>
    </FadeIn>
  </div>
</section>
